# Q1. Reverse an Array (In-Place)
# Link: https://www.geeksforgeeks.org/problems/reverse-an-array/1
def reverse_array(arr):
    left, right = 0, len(arr) - 1
    while left < right:
        arr[left], arr[right] = arr[right], arr[left]
        left += 1
        right -= 1
    return arr

print("Q1:", reverse_array([1, 4, 3, 2, 6, 5]))   # [5, 6, 2, 3, 4, 1]


# Q2. Find Minimum and Maximum Element in Array (In Class)
# Link: https://www.geeksforgeeks.org/problems/find-minimum-and-maximum-element-in-an-array4428/1
def find_min_max(arr):
    mn, mx = arr[0], arr[0]
    for x in arr[1:]:
        if x < mn: mn = x
        if x > mx: mx = x
    return [mn, mx]

print("Q2:", find_min_max([1, 4, 3, 5, 8, 6]))   # [1, 8]


