# Q4. Union of Two Arrays
# Link: https://www.geeksforgeeks.org/problems/union-of-two-arrays3538/1
def union_arrays(a, b):
    return sorted(set(a) | set(b))

print("Q4:", union_arrays([1, 2, 3, 2, 1], [3, 2, 2, 3, 3, 2]))  # [1, 2, 3]


# Q5. Largest Element in Array
# Link: https://www.geeksforgeeks.org/problems/largest-element-in-array4009/0
def largest_element(arr):
    result = arr[0]
    for x in arr[1:]:
        if x > result:
            result = x
    return result

print("Q5:", largest_element([1, 8, 7, 56, 90]))  # 90


