# Q6. Cyclically Rotate Array by One
# Link: https://www.geeksforgeeks.org/problems/cyclically-rotate-an-array-by-one2614/1
def rotate_by_one(arr):
    if not arr:
        return arr
    last = arr[-1]
    for i in range(len(arr) - 1, 0, -1):
        arr[i] = arr[i - 1]
    arr[0] = last
    return arr

print("Q6:", rotate_by_one([1, 2, 3, 4, 5]))  # [5, 1, 2, 3, 4]


# Q7. Maximum Subarray Sum — Kadane's Algorithm
# Link: https://practice.geeksforgeeks.org/problems/kadanes-algorithm/0
def max_subarray_sum(arr):
    max_sum = arr[0]
    current_sum = arr[0]
    for x in arr[1:]:
        current_sum = max(x, current_sum + x)
        max_sum = max(max_sum, current_sum)
    return max_sum

print("Q7:", max_subarray_sum([2, 3, -8, 7, -1, 2, 3]))  # 11


