# Q8. Search Insert Position — Binary Search
# Link: https://leetcode.com/problems/search-insert-position/
def search_insert(nums, target):
    left, right = 0, len(nums)
    while left < right:
        mid = (left + right) // 2
        if nums[mid] < target:
            left = mid + 1
        else:
            right = mid
    return left

print("Q8:", search_insert([1, 3, 5, 6], 5))  # 2
print("Q8:", search_insert([1, 3, 5, 6], 2))  # 1
print("Q8:", search_insert([1, 3, 5, 6], 7))  # 4


# Q9. Two Sum
# Link: https://leetcode.com/problems/two-sum/
def two_sum(nums, target):
    seen = {}
    for i, num in enumerate(nums):
        complement = target - num
        if complement in seen:
            return [seen[complement], i]
        seen[num] = i
    return []

print("Q9:", two_sum([2, 7, 11, 15], 9))  # [0, 1]


# Q10. Minimum Number of Jumps
# Link: https://www.geeksforgeeks.org/problems/minimum-number-of-jumps-1587115620/1
def min_jumps(arr):
    n = len(arr)
    if n == 1:
        return 0
    if arr[0] == 0:
        return -1
    jumps = 0
    current_end = 0
    farthest = 0
    for i in range(n - 1):
        farthest = max(farthest, i + arr[i])
        if i == current_end:
            jumps += 1
            current_end = farthest
            if current_end >= n - 1:
                return jumps
    return -1

print("Q10:", min_jumps([1, 3, 5, 8, 9, 2, 6, 7, 6, 8, 9]))  # 3
print("Q10:", min_jumps([1, 4, 3, 2, 6, 7]))                  # 2
print("Q10:", min_jumps([0, 10, 20]))                          # -1
