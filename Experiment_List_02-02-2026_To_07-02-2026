# Q1. Chocolate Distribution Problem
# Link: https://www.geeksforgeeks.org/problems/chocolate-distribution-problem3825/1
def chocolate_distribution(arr, m):
    if m == 0 or len(arr) < m:
        return 0
    arr.sort()
    min_diff = float('inf')
    for i in range(len(arr) - m + 1):
        diff = arr[i + m - 1] - arr[i]
        min_diff = min(min_diff, diff)
    return min_diff

print("Q1:", chocolate_distribution([3, 4, 1, 9, 56, 7, 9, 12], 5))  # 6
print("Q1:", chocolate_distribution([7, 3, 2, 4, 9, 12, 56], 3))     # 2
print("Q1:", chocolate_distribution([3, 4, 1, 9, 56], 5))            # 55


# Q2. Smallest Subarray with Sum Greater than X
# Link: https://www.geeksforgeeks.org/problems/smallest-subarray-with-sum-greater-than-x5651/1
def smallest_subarray_sum_greater(x, arr):
    n = len(arr)
    min_len = float('inf')
    start = 0
    curr_sum = 0
    for end in range(n):
        curr_sum += arr[end]
        while curr_sum > x and start <= end:
            min_len = min(min_len, end - start + 1)
            curr_sum -= arr[start]
            start += 1
    return 0 if min_len == float('inf') else min_len

print("Q2:", smallest_subarray_sum_greater(51, [1, 4, 45, 6, 0, 19]))  # 3
print("Q2:", smallest_subarray_sum_greater(100, [1, 10, 5, 2, 7]))     # 0


