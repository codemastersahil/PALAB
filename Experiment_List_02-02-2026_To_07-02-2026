# Q3. Three-Way Partitioning
# Link: https://www.geeksforgeeks.org/problems/three-way-partitioning/1
def three_way_partition(arr, a, b):
    low, mid, high = 0, 0, len(arr) - 1
    while mid <= high:
        if arr[mid] < a:
            arr[low], arr[mid] = arr[mid], arr[low]
            low += 1
            mid += 1
        elif arr[mid] > b:
            arr[mid], arr[high] = arr[high], arr[mid]
            high -= 1
        else:
            mid += 1
    return arr

print("Q3:", three_way_partition([1, 2, 3, 3, 4], 1, 2))       # valid partition
print("Q3:", three_way_partition([1, 4, 3, 6, 2, 1], 1, 3))    # valid partition


# Q4. Minimum Swaps to Group Elements <= K
# Link: https://www.geeksforgeeks.org/problems/minimum-swaps-required-to-bring-all-elements-less-than-or-equal-to-k-together4847/1
def min_swaps_k(arr, k):
    n = len(arr)
    count = sum(1 for x in arr if x <= k)
    bad = sum(1 for x in arr[:count] if x > k)
    min_bad = bad
    for i in range(count, n):
        if arr[i] > k:
            bad += 1
        if arr[i - count] > k:
            bad -= 1
        min_bad = min(min_bad, bad)
    return min_bad

print("Q4:", min_swaps_k([2, 1, 5, 6, 3], 3))          # 1
print("Q4:", min_swaps_k([2, 7, 9, 5, 8, 7, 4], 6))    # 2
print("Q4:", min_swaps_k([2, 4, 5, 3, 6, 1, 8], 6))    # 0


# Q5. All Palindrome Numbers in Array (Take Home)
def is_palindrome_num(n):
    s = str(n)
    return s == s[::-1]

def all_palindromes(arr):
    return all(is_palindrome_num(x) for x in arr)

print("Q5:", all_palindromes([111, 222, 333, 444, 555]))  # True
print("Q5:", all_palindromes([121, 131, 20]))             # False


