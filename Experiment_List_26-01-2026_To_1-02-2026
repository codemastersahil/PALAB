# Q3. Minimum Number of Jumps
# Link: https://www.geeksforgeeks.org/problems/minimum-number-of-jumps-1587115620/1
def min_jumps(arr):
    n = len(arr)
    if n == 1:
        return 0
    if arr[0] == 0:
        return -1
    jumps, current_end, farthest = 0, 0, 0
    for i in range(n - 1):
        farthest = max(farthest, i + arr[i])
        if i == current_end:
            jumps += 1
            current_end = farthest
            if current_end >= n - 1:
                return jumps
    return -1

print("Q3:", min_jumps([1, 3, 5, 8, 9, 2, 6, 7, 6, 8, 9]))  # 3
print("Q3:", min_jumps([1, 4, 3, 2, 6, 7]))                  # 2
print("Q3:", min_jumps([0, 10, 20]))                          # -1


# Q4. Find the Duplicate Number (Floyd's Cycle Detection)
# Link: https://leetcode.com/problems/find-the-duplicate-number/
def find_duplicate(nums):
    slow = fast = nums[0]
    while True:
        slow = nums[slow]
        fast = nums[nums[fast]]
        if slow == fast:
            break
    slow = nums[0]
    while slow != fast:
        slow = nums[slow]
        fast = nums[fast]
    return slow

print("Q4:", find_duplicate([1, 3, 4, 2, 2]))  # 2
print("Q4:", find_duplicate([3, 1, 3, 4, 2]))  # 3


# Q5. Merge Two Sorted Arrays Without Extra Space
# Link: https://www.geeksforgeeks.org/problems/merge-two-sorted-arrays-1587115620/1
def merge_sorted_arrays(a, b):
    n, m = len(a), len(b)
    i, j = n - 1, 0
    while i >= 0 and j < m:
        if a[i] > b[j]:
            a[i], b[j] = b[j], a[i]
        i -= 1
        j += 1
    a.sort()
    b.sort()
    return a, b

a, b = [2, 4, 7, 10], [2, 3]
print("Q5:", merge_sorted_arrays(a, b))  # ([2, 2, 3, 4], [7, 10])


# Q6. Merge Overlapping Intervals
# Link: https://leetcode.com/problems/merge-intervals/
def merge_intervals(intervals):
    if not intervals:
        return []
    intervals.sort(key=lambda x: x[0])
    merged = [intervals[0]]
    for start, end in intervals[1:]:
        if start <= merged[-1][1]:
            merged[-1][1] = max(merged[-1][1], end)
        else:
            merged.append([start, end])
    return merged

print("Q6:", merge_intervals([[1,3],[2,6],[8,10],[15,18]]))  # [[1,6],[8,10],[15,18]]
print("Q6:", merge_intervals([[1,4],[4,5]]))                 # [[1,5]]
print("Q6:", merge_intervals([[4,7],[1,4]]))                 # [[1,7]]


