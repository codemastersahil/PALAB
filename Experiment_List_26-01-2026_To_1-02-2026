# Q2. Minimize the Heights
# Link: https://www.geeksforgeeks.org/problems/minimize-the-heights3351/1
def minimize_heights(arr, k):
    n = len(arr)
    if n == 1:
        return 0
    arr.sort()
    result = arr[-1] - arr[0]  # worst case: no change
    for i in range(1, n):
        mn = min(arr[0] + k, arr[i] - k)
        mx = max(arr[i - 1] + k, arr[-1] - k)
        if mn < 0:
            continue
        result = min(result, mx - mn)
    return result

print("Q2:", minimize_heights([1, 5, 8, 10], 2))      # 5
print("Q2:", minimize_heights([3, 9, 12, 16, 20], 3)) # 11


