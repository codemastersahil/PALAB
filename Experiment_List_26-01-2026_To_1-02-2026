# Q9. Array Subset of Another Array
# Link: https://www.geeksforgeeks.org/problems/array-subset-of-another-array2317/1
from collections import Counter

def is_subset(a, b):
    count_a = Counter(a)
    count_b = Counter(b)
    for key, val in count_b.items():
        if count_a[key] < val:
            return False
    return True

print("Q9:", is_subset([11,7,1,13,21,3,7,3],[11,3,7,1,7]))  # True
print("Q9:", is_subset([10,5,2,23,19],[19,5,3]))             # False


# Q10. Triplet Sum in Array
# Link: https://www.geeksforgeeks.org/problems/triplet-sum-in-array1587115621/1
def triplet_sum(arr, target):
    arr.sort()
    n = len(arr)
    for i in range(n - 2):
        left, right = i + 1, n - 1
        while left < right:
            s = arr[i] + arr[left] + arr[right]
            if s == target:
                return True
            elif s < target:
                left += 1
            else:
                right -= 1
    return False

print("Q10:", triplet_sum([1, 4, 45, 6, 10, 8], 13))   # True
print("Q10:", triplet_sum([40, 20, 10, 3, 6, 7], 24))  # False


# Q11. Trapping Rain Water
# Link: https://www.geeksforgeeks.org/problems/trapping-rain-water1587115621/1
def trap_water(arr):
    if len(arr) < 3:
        return 0
    left, right = 0, len(arr) - 1
    left_max = right_max = 0
    water = 0
    while left < right:
        if arr[left] < arr[right]:
            if arr[left] >= left_max:
                left_max = arr[left]
            else:
                water += left_max - arr[left]
            left += 1
        else:
            if arr[right] >= right_max:
                right_max = arr[right]
            else:
                water += right_max - arr[right]
            right -= 1
    return water

print("Q11:", trap_water([3, 0, 1, 0, 4, 0, 2]))      # 10
print("Q11:", trap_water([3, 0, 2, 0, 4]))             # 7
print("Q11:", trap_water([1, 2, 3, 4]))                # 0
print("Q11:", trap_water([2, 1, 5, 3, 1, 0, 4]))      # 9
